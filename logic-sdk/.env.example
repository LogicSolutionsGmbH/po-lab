# Track A harness — dev/staging tenant DB connection (PLACEHOLDERS — fill in before running).
# Mirrors the email-worker MSSQL connection (knex `mssql` client + tedious).

# --- MSSQL connection for the dev/staging tenant DB ---
SDK_DB_SERVER=__PLACEHOLDER_DB_HOST__
SDK_DB_NAME=__PLACEHOLDER_DB_NAME__
SDK_DB_USER=__PLACEHOLDER_DB_USER__
SDK_DB_PASSWORD=__PLACEHOLDER_DB_PASSWORD__
SDK_DB_PORT=1433
SDK_DB_ENCRYPT=false
SDK_DB_TRUST_SERVER_CERT=true

# --- Directorio tenant id for the supplier resolve ---
# = TESch_FacturaExtraida.cd_identityTenant = cd_identityDatosRFC (derived from invoice recipient).
# Prototype: hardcode the processing-office id for the test tenant.
SDK_DIRECTORY_TENANT_ID=__PLACEHOLDER_CD_IDENTITY_DATOSRFC__
