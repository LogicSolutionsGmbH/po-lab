# Copy to `.env` and fill in. All scripts read these.

# Base URL of the Logic Heroes API (note the /api suffix).
API_URL=http://localhost:3401/api

# --- Tenant key registry -----------------------------------------------------
# One API key per tenant. The suffix after LH_KEY_ is the tenant NAME you'll
# refer to below and on the command line (case-insensitive). Add as many as you
# need; for a self-request demo a single tenant is fine.
LH_KEY_ACME=lh_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LH_KEY_GLOBEX=lh_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# --- Default role bindings ---------------------------------------------------
# Which tenant plays each role by default. Names must match an LH_KEY_<NAME>
# above. Override per command with --maker <name> / --taker <name>, e.g.
#   npx tsx create-shipment.ts ... --maker globex --taker acme   (swaps A/B)
# For a self-request demo, point both at the same tenant.
MAKER=acme
TAKER=globex

# --- Legacy single-key mode (optional) ---------------------------------------
# Still supported. Used only when no flag and no binding above resolve a key.
# Leave commented out if you use the registry.
# MAKER_API_KEY=lh_...
# TAKER_API_KEY=lh_...
