# Copy to `.env` and fill in. All scripts read these.

# Base URL of the Logic Heroes API (note the /api suffix).
API_URL=http://localhost:3401/api

# API key for the MAKER / assigner (initiates handshakes, creates journeys & services).
MAKER_API_KEY=lh_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API key for the TAKER / assignee (accepts or rejects handshakes).
# For a self-request demo, this can be the same key as MAKER_API_KEY.
TAKER_API_KEY=lh_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
